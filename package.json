{
  "name": "beam",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Beam desktop app for sharing files and a reliable ecosystem",
  "author": "Reabot6",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.beam.app",
    "productName": "Beam",
    "directories": {
      "output": "dist"
     
    },
     "publish": {
        "provider": "github",
        "owner": "Reabot6",
        "repo": "Beam"
      }
    ,
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "files": [
      "main.js",
      "express.js",
      "index.html",
      "uploads/",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}
